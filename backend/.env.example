
NODE_ENV=development
PORT=5000

# Database
# MONGODB_URI=mongodb://localhost:27017/tradetv_portal

MONGODB_URI=
JWT_EXPIRE=
BCRYPT_ROUNDS=

# CORS
CORS_ORIGIN=

# Supervisor User
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Logging   
LOG_LEVEL=

# Rate limiting (enable in Preview first, then Production after verification)
RATE_LIMIT_ENABLED=false

# Public frontend URL used to build password-reset links
FRONTEND_URL=http://localhost:3000

# SMTP / Nodemailer (example values for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Trade X TV <no-reply@example.com>"

# Public HTTPS image URL for the logo displayed in emails
MAIL_LOGO_URL=https://your-frontend-domain.com/logo.png
SUPPORT_EMAIL=support@example.com
